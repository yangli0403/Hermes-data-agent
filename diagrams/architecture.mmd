graph TD
    subgraph L1[入口与交互层]
        CLI[scripts/cli.py\norbit / vlm 子命令]
        SKILL[skills/*\ncar-orbit-synthesis / vlm-data-synthesis]
        TOOL[tools/*\norbit_* / vlm_* / toolset adapter]
    end

    subgraph L2[编排与流程层]
        RUNNER[VLM Pipeline Runner\n单图最小闭环编排]
        CASCADE[CascadeOrchestrator\n按模式装配验证阶段]
        CONFIG[ConfigLoader\ndefault.yaml + vlm 配置]
    end

    subgraph L3[核心生成层]
        SEED[Visual Seed Engine\n任务配置 → VisualSeed]
        GEN[Visual Generalization Engine\nquestion / answer / prompt / statement]
        IMG[Image Synthesis Coordinator\nprompt → image artifact]
    end

    subgraph L4[验证与追踪层]
        STRUCT[SchemaVerifier\n结构与字段完整性]
        CONSIST[ConsistencyVerifier\nQA / prompt 自洽]
        VISION[VisionConsistencyVerifier\n图像内容一致性]
        TRACE[ProvenanceTracker\n来源链 / 验证链 / 审阅轨迹]
    end

    subgraph L5[模型客户端与提供方适配层]
        FACTORY[Model Client Factory]
        LLM[LLMClient\n文本生成/判定]
        IMGC[ImageClient\n图像生成]
        VLMC[VLMClient\n图像理解/视觉校验]
    end

    subgraph L6[输出与测试层]
        EXPORT[VLM Dataset Adapter\n训练导出 + 审阅导出]
        OUT[(output/vlm)]
        TEST[tests/*\ncontract / mock / smoke]
    end

    CLI --> RUNNER
    SKILL --> TOOL
    TOOL --> RUNNER
    CONFIG --> RUNNER
    RUNNER --> SEED
    SEED --> GEN
    GEN --> IMG
    GEN --> CASCADE
    IMG --> CASCADE
    CASCADE --> STRUCT
    CASCADE --> CONSIST
    CASCADE --> VISION
    STRUCT --> TRACE
    CONSIST --> TRACE
    VISION --> TRACE
    SEED --> TRACE
    GEN --> TRACE
    IMG --> TRACE
    RUNNER --> EXPORT
    TRACE --> EXPORT
    EXPORT --> OUT
    TEST --> SEED
    TEST --> CASCADE
    TEST --> EXPORT
    FACTORY --> LLM
    FACTORY --> IMGC
    FACTORY --> VLMC
    GEN --> LLM
    IMG --> IMGC
    CONSIST --> LLM
    VISION --> VLMC
